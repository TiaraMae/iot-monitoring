# ============================================================
# Environment Template for iot-monitoring
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it contains secrets.
# ============================================================

# --- Flask ---
FLASK_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MIN_32_CHARS

# --- Database (Local PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iot_db
DB_USER=iot_user
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# --- MQTT (HiveMQ Cloud or your own broker) ---
MQTT_HOST=YOUR_MQTT_BROKER.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=YOUR_MQTT_USERNAME
MQTT_PASS=CHANGE_THIS_TO_YOUR_MQTT_PASSWORD

# --- Optional: Neon Cloud Database (used by gas_dryer_test backend only) ---
NEON_DATABASE_URL=postgresql://user:password@host/database?sslmode=require

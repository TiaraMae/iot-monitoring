# ========================================
# IoT Monitoring & Alert System
# Environment Variables Template
# ========================================
# Copy this file to .env and fill in your actual values.
# The application will use these values instead of the built-in defaults.

# ----------------------------------------
# Flask App
# ----------------------------------------
FLASK_SECRET_KEY=change-this-to-a-random-secret-key

# ----------------------------------------
# MQTT Broker (HiveMQ Cloud)
# ----------------------------------------
MQTT_HOST=your-mqtt-broker.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=your-mqtt-username
MQTT_PASS=your-mqtt-password

# ----------------------------------------
# PostgreSQL Database (Local)
# ----------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iot_db
DB_USER=postgres
DB_PASSWORD=your-db-password

# ----------------------------------------
# Neon Cloud Database (Dryer Testing)
# ----------------------------------------
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/db?sslmode=require

# ========================================
# IoT Monitoring & Alert System
# Environment Variables Template
# ========================================
# Copy this file to .env and fill in your actual values.
# The application requires these variables and will fail to start
# if any required value is missing.

# ----------------------------------------
# Flask App (Required)
# ----------------------------------------
FLASK_SECRET_KEY=your-secret-key-here

# ----------------------------------------
# MQTT Broker (HiveMQ Cloud) (Required)
# ----------------------------------------
MQTT_HOST=d57bf82836a7485d9b67b270c681fe6e.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=your-mqtt-username
MQTT_PASS=your-mqtt-password

# ----------------------------------------
# PostgreSQL Database (Local) (Required)
# ----------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iot_db
DB_USER=your-db-username
DB_PASSWORD=your-db-password

# ----------------------------------------
# Neon Cloud Database (Dryer Testing)
# ----------------------------------------
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/db?sslmode=require

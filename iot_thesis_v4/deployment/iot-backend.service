[Unit]
Description=IoT Monitoring Flask Backend
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=iot
Group=iot
WorkingDirectory=/opt/iot-monitoring/iot_thesis_v4
Environment="PATH=/opt/iot-monitoring/venv/bin"
EnvironmentFile=/opt/iot-monitoring/iot_thesis_v4/.env
ExecStart=/opt/iot-monitoring/venv/bin/gunicorn -w 2 -b 127.0.0.1:8000 app:app
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
